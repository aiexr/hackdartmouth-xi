{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  // In Workers Builds, this must match the connected Worker name so the
  // self-service binding resolves during deploy.
  "name": "hackdartmouth-xi",
  "compatibility_date": "2026-04-11",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "keep_vars": true,
  // Public runtime defaults only. Keep secrets in Cloudflare env secrets.
  "vars": {
    "NEXTAUTH_URL": "https://hackdartmouth-xi.alex-6e4.workers.dev",
    "NEXTJS_ENV": "development",
    "GEMINI_MODEL": "gemini-2.5-flash",
    "LLM_PROVIDER": "openai",
    "OPENAI_MODEL": "openai.gpt-oss-120b",
    "MONGODB_DB_NAME": "hackdartmouth"
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "images": {
    "binding": "IMAGES"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "hackdartmouth-xi"
    }
  ],
  // Secrets configured in Cloudflare dashboard - these will be injected at runtime
  "secrets": ["NEXTAUTH_SECRET", "GOOGLE_CLIENT_ID", "GOOGLE_CLIENT_SECRET", "MONGODB_URI", "OPENAI_API_KEY", "GEMINI_API_KEY", "ELEVENLABS_API_KEY", "HEYGEN_API_KEY"]
}
